<Window x:Class="VMCreateVM.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Progress" Height="220" Width="400" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="CommonButton" TargetType="{x:Type Button}">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Background" Value="#FF0078D7"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="ExplanationText" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="StatusText" Grid.Row="0" Style="{StaticResource ExplanationText}" Text="Downloading..."/>
        <TextBlock x:Name="LinkText" Grid.Row="1" Style="{StaticResource ExplanationText}" Text="" Visibility="Visible"/>
        <TextBlock x:Name="SpeedText" Grid.Row="2" Style="{StaticResource ExplanationText}" Text="Download Speed: 0 MB/s"/>
        <ProgressBar x:Name="ProgressBar" Grid.Row="3" Height="20" Minimum="0" Maximum="100" Foreground="Green"/>
        <Button x:Name="CancelButton" Grid.Row="4" Content="Cancel" Style="{StaticResource CommonButton}" HorizontalAlignment="Right" Click="CancelButton_Click"/>
    </Grid>
</Window>