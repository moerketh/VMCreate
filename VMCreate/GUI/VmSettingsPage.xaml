<Page x:Class="VMCreate.VmSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:VMCreate"
      Title="Configure Virtual Machine">
    <Grid Margin="20,10,20,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,0,4">
        <StackPanel FocusManager.FocusedElement="{Binding ElementName=VMNameTextBox}">

            <TextBlock Text="Configure Virtual Machine Settings" Style="{StaticResource TitleText}" Margin="0,0,0,12"/>

            <!-- Selected image summary card -->
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16,12" Margin="0,0,0,12"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Image Source="{Binding SelectedItem.SymbolUri, Converter={StaticResource ImageConverter}}" 
                           Width="48" Height="48" Margin="0,0,14,0" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedItem.Name, FallbackValue='No VM selected'}" 
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="{Binding SelectedItem.Publisher}" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <ui:InfoBar Title="Conversion required" Severity="Warning"
                        Message="The selected VM is not in VHDX format. It will be converted to VHDX using QEMU. If the disk is MBR partitioned it will be cloned to a new GPT partitioned disk using a converter DVD on first VM boot."
                        IsOpen="{Binding IsNotVhdx, Mode=OneWay}" IsClosable="False" Margin="0,0,0,8"/>

            <!-- Inline validation error -->
            <TextBlock Text="{Binding ValidationError}" Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                       FontSize="12" Margin="4,0,4,8" TextWrapping="Wrap"
                       Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVis}}"/>

            <!-- Settings form card -->
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20,16" Margin="0,0,0,12"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel>
                    <!-- VM Name -->
                    <TextBlock Text="VM Name" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,6"/>
                    <ui:TextBox x:Name="VMNameTextBox"
                             Text="{Binding VmName, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14" PlaceholderText="Enter VM name" Margin="0,0,0,16"
                             MaxWidth="500" HorizontalAlignment="Left" MinWidth="300"
                             ToolTip="Enter a unique name for the VM."
                             AutomationProperties.Name="VM Name"/>

                    <!-- Memory slider -->
                    <Grid Margin="0,0,0,16" MaxWidth="500" MinWidth="300" HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Memory" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MemoryDisplay}" FontSize="14"
                                   Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"
                                   HorizontalAlignment="Right"/>
                        <Slider Grid.Row="1" Grid.ColumnSpan="2"
                                Value="{Binding MemoryMB}" Minimum="512" Maximum="32768"
                                TickFrequency="512" IsSnapToTickEnabled="True"
                                SmallChange="512" LargeChange="2048" Margin="0,4,0,0"
                                ToolTip="Allocate memory for the VM (512 MB – 32 GB)"
                                AutomationProperties.Name="Memory in megabytes"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="512 MB" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Bottom" Margin="0,0,0,-16"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="32 GB" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,-16"/>
                    </Grid>

                    <!-- CPU slider -->
                    <Grid Margin="0,16,0,16" MaxWidth="500" MinWidth="300" HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CpuDisplay}" FontSize="14"
                                   Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"
                                   HorizontalAlignment="Right"/>
                        <Slider Grid.Row="1" Grid.ColumnSpan="2"
                                Value="{Binding CpuCount}" Minimum="1" Maximum="32"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                SmallChange="1" LargeChange="4" Margin="0,4,0,0"
                                ToolTip="Number of virtual processors (1 – 32)"
                                AutomationProperties.Name="CPU count"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="1" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Bottom" Margin="0,0,0,-16"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="32" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,-16"/>
                    </Grid>

                    <!-- New Drive Size (only for non-VHDX) -->
                    <StackPanel Visibility="{Binding IsNotVhdx, Converter={StaticResource BoolToVis}}" Margin="0,8,0,0">
                        <TextBlock Text="New Drive Size (GB)" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,6"/>
                        <ui:TextBox x:Name="NewDriveSizeTextBox"
                                 Text="{Binding NewDriveSizeText, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14" PlaceholderText="40"
                                 MaxWidth="200" HorizontalAlignment="Left" MinWidth="120"
                                 PreviewTextInput="NumberValidationTextBox" DataObject.Pasting="TextBoxPasting"
                                 ToolTip="Enter new drive size in GB (at least 10, must be larger than the original disk size)."
                                 AutomationProperties.Name="New drive size in gigabytes"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Options card -->
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20,16" Margin="0,0,0,12"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Options" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,10"/>
                    <CheckBox Content="Enable nested virtualization"
                              IsChecked="{Binding VirtualizationEnabled}"
                              FontSize="14"
                              ToolTip="Allows running Hyper-V or other hypervisors inside this VM."
                              AutomationProperties.Name="Enable nested virtualization"/>
                </StackPanel>
            </Border>

        </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="&lt; Back" Command="{Binding BackCommand}" Style="{StaticResource CommonButton}"
                    AutomationProperties.Name="Go back"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource CommonButton}" Margin="5,0,0,0"
                    AutomationProperties.Name="Cancel wizard"/>
            <ui:Button Command="{Binding NextCommand}" Appearance="Primary"
                    FontSize="14" Margin="9,4,4,4" Padding="12,8"
                    AutomationProperties.Name="Next step">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Next" VerticalAlignment="Center"/>
                    <ui:SymbolIcon Symbol="ArrowRight24" Margin="6,0,0,0"/>
                </StackPanel>
            </ui:Button>
        </StackPanel>
    </Grid>
</Page>