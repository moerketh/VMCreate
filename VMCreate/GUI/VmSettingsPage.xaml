<Page x:Class="VMCreate.VmSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:VMCreate"
      Title="Configure Virtual Machine">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="Auto"/>
            <!-- Selected VM info -->
            <RowDefinition Height="Auto"/>
            <!-- Yellow banner -->
            <RowDefinition Height="Auto"/>
            <!-- Validation error -->
            <RowDefinition Height="*"/>
            <!-- Settings -->
            <RowDefinition Height="Auto"/>
            <!-- Navigation buttons -->
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Configure Virtual Machine Settings" Style="{StaticResource TitleText}"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,10">
            <Image Source="{Binding SelectedItem.SymbolUri, Converter={StaticResource ImageConverter}}" 
                   Width="80" Height="50" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SelectedItem.Name, FallbackValue='No VM selected'}" 
                       Style="{StaticResource ExplanationText}" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <Border Background="Yellow" Padding="10"
                    Visibility="{Binding IsNotVhdx, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="The selected VM is not in VHDX format. It will be converted to VHDX using QEMU. If the disk is MBR partitioned it will be cloned to a new GPT partitioned disk using a converter DVD on first VM boot." 
                           Style="{StaticResource ExplanationText}" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
        <!-- Inline validation error (clears automatically when user types) -->
        <TextBlock Grid.Row="3" Text="{Binding ValidationError}" Foreground="Red"
                   FontFamily="Segoe UI" FontSize="12" Margin="5,0,5,5" TextWrapping="Wrap"
                   Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVis}}"/>
        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="VM Name:" Target="{Binding ElementName=VMNameTextBox}" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="VMNameTextBox" Grid.Row="0" Grid.Column="1"
                     Text="{Binding VmName, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="Segoe UI" FontSize="14"
                     ToolTip="Enter a unique name for the VM."
                     AutomationProperties.Name="VM Name"/>
            <Label Grid.Row="1" Grid.Column="0" Content="Memory (MB):" Target="{Binding ElementName=MemoryTextBox}" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="MemoryTextBox" Grid.Row="1" Grid.Column="1"
                     Text="{Binding MemoryText, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="Segoe UI" FontSize="14"
                     PreviewTextInput="NumberValidationTextBox" DataObject.Pasting="TextBoxPasting"
                     ToolTip="Enter memory in MB (at least 512)."
                     AutomationProperties.Name="Memory in megabytes"/>
            <Label Grid.Row="2" Grid.Column="0" Content="CPU Count:" Target="{Binding ElementName=CPUTextBox}" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="CPUTextBox" Grid.Row="2" Grid.Column="1"
                     Text="{Binding CpuText, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="Segoe UI" FontSize="14"
                     PreviewTextInput="NumberValidationTextBox" DataObject.Pasting="TextBoxPasting"
                     ToolTip="Enter CPU count (at least 1)."
                     AutomationProperties.Name="CPU count"/>
            <CheckBox Grid.Row="3" Grid.Column="1"
                      Content="Virtualization Enabled"
                      IsChecked="{Binding VirtualizationEnabled}"
                      FontFamily="Segoe UI" FontSize="14" Margin="0,5,0,5"
                      ToolTip="Enable nested virtualization if needed."
                      AutomationProperties.Name="Enable nested virtualization"/>
            <Label Grid.Row="4" Grid.Column="0" Content="New Drive Size (GB):"
                   Target="{Binding ElementName=NewDriveSizeTextBox}" Style="{StaticResource LabelStyle}"
                   Visibility="{Binding IsNotVhdx, Converter={StaticResource BoolToVis}}"/>
            <TextBox x:Name="NewDriveSizeTextBox" Grid.Row="4" Grid.Column="1"
                     Text="{Binding NewDriveSizeText, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="Segoe UI" FontSize="14"
                     PreviewTextInput="NumberValidationTextBox" DataObject.Pasting="TextBoxPasting"
                     ToolTip="Enter new drive size in GB (at least 10, must be larger than the original disk size)."
                     Visibility="{Binding IsNotVhdx, Converter={StaticResource BoolToVis}}"
                     AutomationProperties.Name="New drive size in gigabytes"/>
        </Grid>
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="&lt; Back" Command="{Binding BackCommand}" Style="{StaticResource CommonButton}"
                    AutomationProperties.Name="Go back"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource CommonButton}" Margin="5,0,0,0"
                    AutomationProperties.Name="Cancel wizard"/>
            <Button Content="Next &gt;" Command="{Binding NextCommand}" Style="{StaticResource CommonButton}" Margin="5,0,0,0"
                    AutomationProperties.Name="Next step"/>
        </StackPanel>
    </Grid>
</Page>