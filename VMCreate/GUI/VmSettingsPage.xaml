<Page x:Class="VMCreate.VmSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:VMCreate"
      Title="Configure Virtual Machine">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="Auto"/>
            <!-- Selected VM info -->
            <RowDefinition Height="Auto"/>
            <!-- Yellow banner -->
            <RowDefinition Height="*"/>
            <!-- Settings -->
            <RowDefinition Height="Auto"/>
            <!-- Navigation buttons -->
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Configure Virtual Machine Settings" Style="{StaticResource TitleText}"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,10">
            <Image Source="{Binding SelectedItem.SymbolUri, Converter={StaticResource ImageConverter}}" 
                   Width="80" Height="50" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SelectedItem.Name, FallbackValue='No VM selected'}" 
                       Style="{StaticResource ExplanationText}" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <Border x:Name="ConversionBanner" Background="Yellow" Padding="10" Visibility="Collapsed">
                <TextBlock Text="The selected VM is not in VHDX format. It will be converted to VHDX using QEMU. If the disk is MBR partitioned it will be cloned to a new GPT partitioned disk using a converter DVD on first VM boot." 
                           Style="{StaticResource ExplanationText}" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="VM Name:" Target="{Binding ElementName=VMNameTextBox}" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="VMNameTextBox" Grid.Row="0" Grid.Column="1" FontFamily="Segoe UI" FontSize="14" ToolTip="Enter a unique name for the VM."/>
            <Label Grid.Row="1" Grid.Column="0" Content="Memory (MB):" Target="{Binding ElementName=MemoryTextBox}" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="MemoryTextBox" Grid.Row="1" Grid.Column="1" FontFamily="Segoe UI" FontSize="14" PreviewTextInput="NumberValidationTextBox" DataObject.Pasting="TextBoxPasting" ToolTip="Enter memory in MB (at least 512)."/>
            <Label Grid.Row="2" Grid.Column="0" Content="CPU Count:" Target="{Binding ElementName=CPUTextBox}" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="CPUTextBox" Grid.Row="2" Grid.Column="1" FontFamily="Segoe UI" FontSize="14" PreviewTextInput="NumberValidationTextBox" DataObject.Pasting="TextBoxPasting" ToolTip="Enter CPU count (at least 1)."/>
            <CheckBox x:Name="VirtualizationEnabledCheckBox" Grid.Row="3" Grid.Column="1" Content="Virtualization Enabled" FontFamily="Segoe UI" FontSize="14" Margin="0,5,0,5" ToolTip="Enable nested virtualization if needed."/>
            <Label x:Name="NewDriveLabel" Grid.Row="4" Grid.Column="0" Content="New Drive Size (GB):" Target="{Binding ElementName=NewDriveSizeTextBox}" Style="{StaticResource LabelStyle}" Visibility="Collapsed"/>
            <TextBox x:Name="NewDriveSizeTextBox" Grid.Row="4" Grid.Column="1" FontFamily="Segoe UI" FontSize="14" PreviewTextInput="NumberValidationTextBox" DataObject.Pasting="TextBoxPasting" ToolTip="Enter new drive size in GB (at least 10, must be larger than the original disk size)." Visibility="Collapsed"/>
        </Grid>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="backButton" Content="&lt; Back" Style="{StaticResource CommonButton}" Click="backButton_Click"/>
            <Button x:Name="cancelButton" Content="Cancel" Style="{StaticResource CommonButton}" Margin="5,0,0,0" Click="cancelButton_Click"/>
            <Button x:Name="nextButton" Content="Next &gt;" Style="{StaticResource CommonButton}" Margin="5,0,0,0" Click="nextButton_Click"/>
        </StackPanel>
    </Grid>
</Page>