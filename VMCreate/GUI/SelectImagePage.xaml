<!-- SelectImagePage.xaml -->
<Page x:Class="VMCreate.SelectImagePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:VMCreate"
      Title="Select Virtual Machine Image">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Dismissible error banner (theme-aware via InfoBar) -->
        <ui:InfoBar Grid.Row="0" Title="Error" Severity="Error"
                    Message="{Binding ErrorMessage}"
                    IsOpen="{Binding HasError, Mode=OneWay}"
                    IsClosable="True" Margin="0,0,0,6"/>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="350" MaxWidth="500"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <!-- Gallery list -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListBox Grid.Row="0" ItemsSource="{Binding GalleryView}"
                         SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                         SelectionMode="Single" ScrollViewer.VerticalScrollBarVisibility="Auto" 
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource GalleryItemStyle}"
                         HorizontalContentAlignment="Stretch"
                         AutomationProperties.Name="Gallery images">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DockPanel Grid.Column="0" VerticalAlignment="Center">
                                    <Image DockPanel.Dock="Left" Source="{Binding SymbolUri, Converter={StaticResource ImageConverter}}" Width="80" Height="50" VerticalAlignment="Center" />
                                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- Gold star for recommended items -->
                                            <TextBlock Text="★" FontSize="18" Foreground="#FFD700"
                                                       VerticalAlignment="Center" Margin="5,0,3,0"
                                                       ToolTip="Recommended"
                                                       Visibility="{Binding IsRecommended, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource ExplanationText}" FontWeight="Bold" FontSize="16" TextAlignment="Left" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Publisher}" Style="{StaticResource PublisherText}" TextAlignment="Left" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DockPanel>
                                <!-- Right-side badges stacked vertically -->
                                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding FileType}" Style="{StaticResource PillLabelStyle}"/>
                                    <TextBlock Text="Security" Style="{StaticResource SecurityPillStyle}"
                                               Visibility="{Binding IsSecurity, Converter={StaticResource BoolToVis}}"
                                               ToolTip="Security / penetration-testing distribution"/>
                                    <TextBlock Text="Pre-installed" Style="{StaticResource PreInstalledPillStyle}"
                                               Visibility="{Binding IsPreInstalled, Converter={StaticResource BoolToVis}}"
                                               ToolTip="Ready-to-run disk image — no manual OS installation required"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <!-- Inline loading indicator (non-blocking) — shown while loaders are still running -->
                <Border Grid.Row="1"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4" Padding="10,8" Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16"/>
                        <TextBlock Text="Loading more images&#x2026;"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
            <!-- Detail panel — bound directly to SelectedItem properties -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="10,0,10,0">
            <StackPanel>
                <Image Source="{Binding SelectedItem.ThumbnailUri, Converter={StaticResource ImageConverter}}"
                       Stretch="Uniform" MaxHeight="300" Margin="0,0,0,10"/>
                <!-- Recommended / Security badges in detail panel -->
                <StackPanel Orientation="Horizontal" Margin="5,0,0,6"
                            Visibility="{Binding SelectedItem.IsSecurity, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="★ Recommended" Style="{StaticResource ExplanationText}" Foreground="#FFD700" FontWeight="SemiBold"
                               Visibility="{Binding SelectedItem.IsRecommended, Converter={StaticResource BoolToVis}}"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Security Distribution" Style="{StaticResource SecurityPillStyle}" VerticalAlignment="Center"
                               Margin="0"/>
                </StackPanel>
                <TextBlock Text="{Binding SelectedItem.Name, StringFormat='Name: {0}'}"
                           Style="{StaticResource ExplanationText}" FontWeight="Bold" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding SelectedItem.Publisher, StringFormat='Publisher: {0}'}"
                           Style="{StaticResource ExplanationText}" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding SelectedItem.Version, StringFormat='Version: {0}'}"
                           Style="{StaticResource ExplanationText}" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding SelectedItem.LastUpdated, Converter={StaticResource DateConverter}, StringFormat='Last Updated: {0}'}"
                           Style="{StaticResource ExplanationText}" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding SelectedItem.DiskUri, StringFormat='Download URL: {0}'}"
                           Style="{StaticResource ExplanationText}" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding SelectedItem.Description, StringFormat='Description: {0}'}"
                           Style="{StaticResource ExplanationText}" TextWrapping="Wrap"/>
            </StackPanel>
            </ScrollViewer>
        </Grid>
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <CheckBox Content="Show ISO installers"
                      IsChecked="{Binding ShowIsoInstallers}"
                      HorizontalAlignment="Left" VerticalAlignment="Center"
                      FontSize="12" Opacity="0.8"
                      ToolTip="ISO images require manual OS installation inside the VM"
                      AutomationProperties.Name="Show ISO installer images"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource CommonButton}"
                    AutomationProperties.Name="Cancel wizard"/>
            <ui:Button Command="{Binding NextCommand}" Appearance="Primary"
                    FontSize="14" Margin="9,4,4,4" Padding="12,8"
                    AutomationProperties.Name="Next step">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Next" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
                    <ui:SymbolIcon Symbol="ArrowRight24" Margin="6,0,0,0"
                                   Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
                </StackPanel>
            </ui:Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>