<!-- SelectImagePage.xaml -->
<Page x:Class="VMCreate.SelectImagePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:VMCreate"
      Title="Select Virtual Machine Image">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Select a Virtual Machine Image" Style="{StaticResource TitleText}"/>
        <!-- Dismissible error banner -->
        <Border Grid.Row="1" Background="#FFF2DEDE" BorderBrush="#FFE87070" BorderThickness="1"
                Padding="10,8" Margin="0,0,0,6" CornerRadius="4"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding ErrorMessage}" Foreground="#FFB33A3A"
                           FontFamily="Segoe UI" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Command="{Binding DismissErrorCommand}" Background="Transparent" BorderThickness="0"
                        Foreground="#FFB33A3A" Cursor="Hand" Padding="6,2" VerticalAlignment="Center"
                        ToolTip="Dismiss" AutomationProperties.Name="Dismiss error"/>
            </Grid>
        </Border>
        <TextBox Grid.Row="2" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,10,0,10" FontFamily="Segoe UI" FontSize="14"
                 AutomationProperties.Name="Search gallery images"/>
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="350" MaxWidth="500"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Gallery list -->
            <Grid Grid.Column="0">
                <ListBox ItemsSource="{Binding GalleryView}"
                         SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                         SelectionMode="Single" ScrollViewer.VerticalScrollBarVisibility="Auto" 
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource GalleryItemStyle}"
                         HorizontalContentAlignment="Stretch"
                         AutomationProperties.Name="Gallery images">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Image Source="{Binding SymbolUri, Converter={StaticResource ImageConverter}}" Width="80" Height="50" VerticalAlignment="Center" />
                                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource ExplanationText}" FontWeight="Bold" TextAlignment="Left"/>
                                        <TextBlock Text="{Binding Publisher}" Style="{StaticResource PublisherText}" TextAlignment="Left"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding FileType}" Style="{StaticResource PillLabelStyle}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <!-- Loading overlay shown until all gallery loaders have completed -->
                <Border Background="#CC1E1E2E"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Loading gallery&#x2026;"
                                   Foreground="White" FontFamily="Segoe UI" FontSize="18"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Fetching available images from the internet"
                                   Foreground="#FFAAAAAA" FontFamily="Segoe UI" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
            <!-- Detail panel — bound directly to SelectedItem properties -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="10,0,10,0">
            <StackPanel>
                <Image Source="{Binding SelectedItem.ThumbnailUri, Converter={StaticResource ImageConverter}}"
                       Stretch="Uniform" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding SelectedItem.Name, StringFormat='Name: {0}'}"
                           Style="{StaticResource ExplanationText}" FontWeight="Bold" Margin="0,0,0,-5"/>
                <TextBlock Text="{Binding SelectedItem.Publisher, StringFormat='Publisher: {0}'}"
                           Style="{StaticResource ExplanationText}" Margin="0,0,0,-5"/>
                <TextBlock Text="{Binding SelectedItem.Version, StringFormat='Version: {0}'}"
                           Style="{StaticResource ExplanationText}" Margin="0,0,0,-5"/>
                <TextBlock Text="{Binding SelectedItem.LastUpdated, StringFormat='Last Updated: {0}'}"
                           Style="{StaticResource ExplanationText}" Margin="0,0,0,-5"/>
                <TextBlock Text="{Binding SelectedItem.DiskUri, StringFormat='Download URL: {0}'}"
                           Style="{StaticResource ExplanationText}" Margin="0,0,0,-5"/>
                <TextBlock Text="{Binding SelectedItem.Description, StringFormat='Description: {0}'}"
                           Style="{StaticResource ExplanationText}" TextWrapping="Wrap"/>
            </StackPanel>
            </ScrollViewer>
        </Grid>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource CommonButton}"
                    AutomationProperties.Name="Cancel wizard"/>
            <Button Content="Next &gt;" Command="{Binding NextCommand}" Style="{StaticResource CommonButton}" Margin="5,0,0,0"
                    AutomationProperties.Name="Next step"/>
        </StackPanel>
    </Grid>
</Page>