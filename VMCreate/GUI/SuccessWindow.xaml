<Window x:Class="VMCreate.SuccessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Success" Height="150" Width="300" WindowStartupLocation="CenterOwner">
    <!-- Styles inherited from App.xaml -->
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Style="{StaticResource ExplanationText}" Text="VM created successfully!"/>
        <Button x:Name="OKButton" Grid.Row="1" Content="OK" Style="{StaticResource CommonButton}" HorizontalAlignment="Right" Click="OKButton_Click"/>
    </Grid>
</Window>