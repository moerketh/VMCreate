<ui:FluentWindow x:Class="VMCreate.SuccessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Success" Height="260" Width="420" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ui:TitleBar Grid.Row="0" Title="Success"/>
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="36" Foreground="{DynamicResource SystemFillColorSuccessBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="SuccessMessage" Style="{StaticResource ExplanationText}" FontSize="14"
                       HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Content="Connect to VM" Icon="{ui:SymbolIcon DesktopFlow24}" Appearance="Primary"
                       FontSize="14" Margin="4" Padding="12,8" Click="ConnectButton_Click"
                       ToolTip="Launch VM Connect for this VM"
                       AutomationProperties.Name="Connect to virtual machine"/>
            <ui:Button Content="Hyper-V Manager" Icon="{ui:SymbolIcon Server24}" Appearance="Secondary"
                       FontSize="14" Margin="4" Padding="12,8" Click="HyperVManagerButton_Click"
                       ToolTip="Open Hyper-V Manager"
                       AutomationProperties.Name="Open Hyper-V Manager"/>
            <Button Content="Close" Style="{StaticResource CommonButton}" Click="OKButton_Click"
                    AutomationProperties.Name="Close dialog"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>