<ui:FluentWindow x:Class="VMCreate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:VMCreate"
        Title="New Virtual Machine Wizard" Height="652" Width="1000"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="New Virtual Machine Wizard">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:Button x:Name="ThemeToggleButton"
                               Icon="{ui:SymbolIcon WeatherMoon24}"
                               Click="ToggleTheme_Click"
                               Appearance="Transparent"
                               ToolTip="Toggle dark / light theme"
                               AutomationProperties.Name="Toggle theme"
                               Margin="0,0,8,0" Padding="4"/>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- Wizard step indicator -->
        <Border Grid.Row="1" Padding="16,8" Background="{DynamicResource ControlFillColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel x:Name="Step1Panel" Orientation="Horizontal" Margin="0,0,6,0">
                    <ui:SymbolIcon x:Name="Step1Icon" Symbol="Image24" FontSize="16" Margin="0,0,4,0"/>
                    <TextBlock x:Name="Step1Text" Text="Select Image" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>
                <TextBlock Text="―" VerticalAlignment="Center" Margin="6,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13"/>
                <StackPanel x:Name="Step2Panel" Orientation="Horizontal" Margin="6,0">
                    <ui:SymbolIcon x:Name="Step2Icon" Symbol="Settings24" FontSize="16" Margin="0,0,4,0"/>
                    <TextBlock x:Name="Step2Text" Text="Configure" VerticalAlignment="Center" FontSize="13"/>
                </StackPanel>
                <TextBlock Text="―" VerticalAlignment="Center" Margin="6,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13"/>
                <StackPanel x:Name="Step3Panel" Orientation="Horizontal" Margin="6,0">
                    <ui:SymbolIcon x:Name="Step3Icon" Symbol="Wrench24" FontSize="16" Margin="0,0,4,0"/>
                    <TextBlock x:Name="Step3Text" Text="Customize" VerticalAlignment="Center" FontSize="13"/>
                </StackPanel>
                <TextBlock Text="―" VerticalAlignment="Center" Margin="6,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13"/>
                <StackPanel x:Name="Step4Panel" Orientation="Horizontal" Margin="6,0,0,0">
                    <ui:SymbolIcon x:Name="Step4Icon" Symbol="Rocket24" FontSize="16" Margin="0,0,4,0"/>
                    <TextBlock x:Name="Step4Text" Text="Deploy" VerticalAlignment="Center" FontSize="13"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Notification banner -->
        <ui:InfoBar x:Name="NotificationBar" Grid.Row="2"
                    IsOpen="False" IsClosable="True" Margin="8,0,8,4"/>

        <Frame x:Name="_mainFrame" Grid.Row="3" NavigationUIVisibility="Hidden" />
    </Grid>
</ui:FluentWindow>