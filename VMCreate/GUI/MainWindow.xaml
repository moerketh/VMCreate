<ui:FluentWindow x:Class="VMCreate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:VMCreate"
        Title="New Virtual Machine Wizard" Height="652" Width="1000"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="New Virtual Machine Wizard">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:Button x:Name="ThemeToggleButton"
                               Icon="{ui:SymbolIcon WeatherMoon24}"
                               Click="ToggleTheme_Click"
                               Appearance="Transparent"
                               ToolTip="Toggle dark / light theme"
                               AutomationProperties.Name="Toggle theme"
                               Margin="0,0,8,0" Padding="4"/>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- Notification banner -->
        <ui:InfoBar x:Name="NotificationBar" Grid.Row="1"
                    IsOpen="False" IsClosable="True" Margin="8,0,8,4"/>

        <Frame x:Name="_mainFrame" Grid.Row="2" NavigationUIVisibility="Hidden" />
    </Grid>
</ui:FluentWindow>