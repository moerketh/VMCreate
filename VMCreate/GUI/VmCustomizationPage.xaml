<Page x:Class="VMCreate.VmCustomizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:VMCreate"
      Title="Configure Virtual Machine">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="Auto"/>
            <!-- Selected VM info -->
            <RowDefinition Height="Auto"/>
            <!-- Yellow banner -->
            <RowDefinition Height="*"/>
            <!-- Settings -->
            <RowDefinition Height="Auto"/>
            <!-- Navigation buttons -->
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Configure Virtual Machine Customizations" Style="{StaticResource TitleText}"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,10">
            <Image Source="{Binding SelectedItem.SymbolUri, Converter={StaticResource ImageConverter}}" 
                   Width="80" Height="50" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SelectedItem.Name, FallbackValue='No VM selected'}" 
                       Style="{StaticResource ExplanationText}" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <Border Background="Yellow" Padding="10"
                    Visibility="{Binding IsNotVhdx, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="The selected VM is not in VHDX format. It will be converted to VHDX using QEMU. If the disk is MBR partitioned it will be cloned to a new GPT partitioned disk using a converter DVD on first VM boot." 
                           Style="{StaticResource ExplanationText}" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Configure xrdp for Hyper-V Enhanced Session support"
                   Target="{Binding ElementName=XrdpCheckbox}" Style="{StaticResource LabelStyle}"/>
            <CheckBox x:Name="XrdpCheckbox" Grid.Column="1"
                      IsChecked="{Binding ConfigureXrdp}"
                      ToolTip="Configure xrdp"
                      AutomationProperties.Name="Configure xrdp for enhanced session"/>
        </Grid>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="&lt; Back" Command="{Binding BackCommand}" Style="{StaticResource CommonButton}"
                    AutomationProperties.Name="Go back"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource CommonButton}" Margin="5,0,0,0"
                    AutomationProperties.Name="Cancel wizard"/>
            <Button Content="Finish" Command="{Binding FinishCommand}" Style="{StaticResource CommonButton}" Margin="5,0,0,0"
                    AutomationProperties.Name="Finish and create VM"/>
        </StackPanel>
    </Grid>
</Page>