<!-- DeployPage.xaml -->
<Page x:Class="VMCreate.DeployPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:VMCreate"
      KeepAlive="False"
      Title="Deploy Virtual Machine">
    <Page.Resources>
        <local:PhaseStatusToBrushConverter      x:Key="StatusToBrush"/>
        <local:PhaseShowBarConverter             x:Key="ShowBar"/>
        <local:NullToCollapsedConverter          x:Key="NullToCollapsed"/>
        <local:InverseBoolToVisibilityConverter  x:Key="InverseBoolToVis"/>
        <local:IndentLevelToMarginConverter       x:Key="IndentMargin"/>
        <BooleanToVisibilityConverter            x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Margin="20,10,20,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Image card: selected gallery item -->
        <Border Grid.Row="0" CornerRadius="8" Padding="12"
                BorderThickness="1"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0"
                       Source="{Binding SelectedItem.SymbolUri, Converter={StaticResource ImageConverter}}"
                       Width="48" Height="48" Margin="0,0,14,0"
                       VerticalAlignment="Center" Stretch="Uniform"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding VmName}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0">
                        <Run Text="{Binding SelectedItem.Name, Mode=OneWay}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding SelectedItem.Publisher, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="1" Text="Deploy Virtual Machine" Style="{StaticResource TitleText}" Margin="0,0,0,8"/>

        <!-- Phase cards -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,0,4">
            <ItemsControl ItemsSource="{Binding Phases}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:DeploymentPhase}">
                        <Border CornerRadius="8" Padding="16,12"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                Margin="{Binding IndentLevel, Converter={StaticResource IndentMargin}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Status icon (left) -->
                                <ui:SymbolIcon Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                                               Symbol="{Binding DisplayIcon}"
                                               FontSize="24" Margin="0,0,14,0" VerticalAlignment="Center"
                                               Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"/>

                                <!-- Phase name + description -->
                                <TextBlock Grid.Column="1" Grid.Row="0"
                                           Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                                <TextBlock Grid.Column="1" Grid.Row="1"
                                           Text="{Binding Description}" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>

                                <!-- Progress text (speed, URI, error) -->
                                <TextBlock Grid.Column="1" Grid.Row="2"
                                           Text="{Binding ProgressText}" FontSize="11"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           TextWrapping="Wrap" Margin="0,2,0,0"
                                           Visibility="{Binding ProgressText, Converter={StaticResource NullToCollapsed}}"/>

                                <!-- Progress bar (active + determinate percentage) -->
                                <ProgressBar Grid.Column="1" Grid.Row="3" Grid.ColumnSpan="2"
                                             Height="4" Margin="0,6,0,0" Minimum="0" Maximum="100"
                                             Value="{Binding ProgressPercentage, Mode=OneWay}"
                                             Visibility="{Binding Status, Converter={StaticResource ShowBar}}"/>

                                <!-- Right-side: indeterminate spinner when active -->
                                <ui:ProgressRing Grid.Column="2" Grid.Row="0" Grid.RowSpan="2"
                                                 IsIndeterminate="True" Width="24" Height="24"
                                                 VerticalAlignment="Center" Margin="10,0,0,0"
                                                 Visibility="{Binding IsIndeterminate, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Bottom action bar -->
        <StackPanel Grid.Row="3" Margin="0,10,0,0">
            <!-- Error banner -->
            <ui:InfoBar Title="Deployment failed" Severity="Error"
                        Message="{Binding ErrorMessage}"
                        IsOpen="{Binding HasError, Mode=OneWay}"
                        IsClosable="False" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Cancel (shown while deploying) -->
                <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource CommonButton}"
                        Visibility="{Binding IsDeploying, Converter={StaticResource BoolToVis}}"
                        AutomationProperties.Name="Cancel deployment"/>

                <!-- Post-success buttons -->
                <ui:Button Content="Connect to VM" Appearance="Primary"
                           Command="{Binding ConnectToVmCommand}"
                           FontSize="14" Margin="4" Padding="12,8"
                           Visibility="{Binding IsComplete, Converter={StaticResource BoolToVis}}"
                           AutomationProperties.Name="Connect to virtual machine">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="DesktopFlow24"/></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Hyper-V Manager" Appearance="Secondary"
                           Command="{Binding OpenHyperVManagerCommand}"
                           FontSize="14" Margin="4" Padding="12,8"
                           Visibility="{Binding IsComplete, Converter={StaticResource BoolToVis}}"
                           AutomationProperties.Name="Open Hyper-V Manager">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Server24"/></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="New VM" Appearance="Secondary"
                           Command="{Binding NewVmCommand}"
                           FontSize="14" Margin="4" Padding="12,8"
                           Visibility="{Binding IsFinished, Converter={StaticResource BoolToVis}}"
                           AutomationProperties.Name="Create another virtual machine">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Add24"/></ui:Button.Icon>
                </ui:Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
