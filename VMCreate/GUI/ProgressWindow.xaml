<ui:FluentWindow x:Class="VMCreate.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Progress" Height="260" Width="500" WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ui:TitleBar Grid.Row="0" Title="Progress"/>
        <Grid Grid.Row="1">
            <TextBlock x:Name="StatusText" Style="{StaticResource ExplanationText}" Text="Downloading..."/>
            <TextBlock x:Name="PercentText" HorizontalAlignment="Right" Style="{StaticResource ExplanationText}" Text="0%"/>
        </Grid>
        <TextBlock x:Name="LinkText" Grid.Row="2" Style="{StaticResource ExplanationText}" Text=""/>
        <TextBlock x:Name="SpeedText" Grid.Row="3" Style="{StaticResource ExplanationText}" Text="Download Speed: 0 MB/s"/>
        <ProgressBar x:Name="ProgressBar" Grid.Row="4" Height="20" Minimum="0" Maximum="100"
                     AutomationProperties.Name="Operation progress"/>
        <Button x:Name="CancelButton" Grid.Row="5" Content="Cancel" Style="{StaticResource CommonButton}" HorizontalAlignment="Right" Click="CancelButton_Click"/>
    </Grid>
</ui:FluentWindow>