<Window x:Class="VMCreateVM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Virtual Machine" Height="652" Width="1000">
    <Window.Resources>
        <Style x:Key="TitleText" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style x:Key="PublisherText" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FF808080"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style x:Key="ExplanationText" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style x:Key="CommonButton" TargetType="{x:Type Button}">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Background" Value="#FF0078D7"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="GalleryItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFF0F0F0"/>
                    <Setter Property="BorderBrush" Value="#FF0078D7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ExpanderStyle" TargetType="{x:Type Expander}">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Select a Virtual Machine Image" Style="{StaticResource TitleText}"/>
        <TextBox Grid.Row="1" x:Name="SearchTextBox" Margin="0,10,0,10" FontFamily="Segoe UI" FontSize="14"/>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="494"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ListBox Grid.Column="0" x:Name="GalleryListBox" SelectionMode="Single" ScrollViewer.VerticalScrollBarVisibility="Auto" 
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" ItemContainerStyle="{StaticResource GalleryItemStyle}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ListBox}}" Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Width="450" Margin="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="{Binding SymbolUri}" Width="80" Height="50" Margin="0,0,0,0" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" Style="{StaticResource ExplanationText}" FontWeight="Bold" TextAlignment="Left"/>
                                <TextBlock Text="{Binding Publisher}" Style="{StaticResource PublisherText}" TextAlignment="Left"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel Grid.Column="1" Margin="10,0,10,0">
                <Image x:Name="DetailScreenshot" Width="400" Height="199" Margin="0,0,0,10"/>
                <TextBlock x:Name="DetailName" Style="{StaticResource ExplanationText}" FontWeight="Bold" Margin="0,0,0,-5"/>
                <TextBlock x:Name="DetailPublisher" Style="{StaticResource ExplanationText}" Margin="0,0,0,-5"/>
                <TextBlock x:Name="DetailVersion" Style="{StaticResource ExplanationText}" Margin="0,0,0,-5"/>
                <TextBlock x:Name="DetailLastUpdated" Style="{StaticResource ExplanationText}" Margin="0,0,0,-5"/>
                <TextBlock x:Name="DetailDescription" Style="{StaticResource ExplanationText}" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="3" Margin="0,10,0,0">
            <Expander Header="VM Settings" Style="{StaticResource ExpanderStyle}">
                <StackPanel Orientation="Vertical" Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                        <TextBlock Text="VM Name:" Style="{StaticResource ExplanationText}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="VMNameTextBox" Width="150" FontFamily="Segoe UI" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                        <TextBlock Text="Memory (MB):" Style="{StaticResource ExplanationText}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="MemoryTextBox" Width="100" Text="2048" FontFamily="Segoe UI" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                        <TextBlock Text="CPU Count:" Style="{StaticResource ExplanationText}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="CPUTextBox" Width="50" Text="2" FontFamily="Segoe UI" FontSize="14"/>
                    </StackPanel>
                    <CheckBox x:Name="VirtualizationEnabledCheckBox" Content="Virtualization Enabled" FontFamily="Segoe UI" FontSize="14" Margin="0,5,0,5"/>
                </StackPanel>
            </Expander>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                <Button x:Name="CreateVMButton" Content="Create VM" Style="{StaticResource CommonButton}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>